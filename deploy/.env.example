# deploy/.env — variáveis do stack de produção (Docker Compose).
# Copie para deploy/.env NO SERVIDOR e preencha. NUNCA versione o .env real.
#
#   cp deploy/.env.example deploy/.env && nano deploy/.env
#
# ── Banco (Postgres em container) ────────────────────────────────────────────
DB_NAME=cockpit_ref
DB_USER=cockpit_user
DB_PASSWORD=__defina_uma_senha_forte__

# ── IA consultiva (FastAPI + Claude) ─────────────────────────────────────────
ANTHROPIC_API_KEY=__sua_chave_anthropic__
LLM_MODEL=claude-opus-4-8
IA_API_KEY=__chave_para_proteger_o_endpoint_/perguntar__

# ── n8n (operador) ───────────────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=__senha_forte_n8n__
# Se usar domínio/HTTPS para o n8n, ajuste:
# N8N_HOST=n8n.seu-dominio.com
# N8N_PROTOCOL=https
# N8N_WEBHOOK_URL=https://n8n.seu-dominio.com/

# ── Grafana (dashboard do cliente) ───────────────────────────────────────────
GF_ADMIN_PASSWORD=__senha_forte_grafana__

# ── Front door (Caddy) ───────────────────────────────────────────────────────
# IP/HTTP:     SITE_ADDRESS=:80          e  PUBLIC_URL=http://76.13.172.100
# Domínio/TLS: SITE_ADDRESS=cockpit.seu-dominio.com  e  PUBLIC_URL=https://cockpit.seu-dominio.com
SITE_ADDRESS=:80
PUBLIC_URL=http://76.13.172.100

# ── Fase 2 (COR) — preencher quando o cliente fornecer ───────────────────────
# COR_BASE_URL=https://api.cor...
# COR_API_TOKEN=__token_do_cliente__
