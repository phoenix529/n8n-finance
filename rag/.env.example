# =============================================================================
# Cockpit Financeiro Estratégico — exemplo de configuração (.env)
# =============================================================================
# Copie para .env e ajuste. NUNCA versione o .env real com segredos.
#   cp .env.example .env
# Os scripts carregam automaticamente o .env (via python-dotenv se instalado).
# =============================================================================

# --- Anthropic Claude (geração das respostas em ask.py) ----------------------
# Chave da API Anthropic. Obrigatória para chamadas reais ao Claude.
ANTHROPIC_API_KEY=sk-ant-...

# Modelo de geração. Default: claude-opus-4-8 (mais capaz).
# Alternativa de custo: claude-sonnet-4-6.
LLM_MODEL=claude-opus-4-8

# --- PostgreSQL 16 + pgvector ------------------------------------------------
PGHOST=localhost
PGPORT=5432
PGDATABASE=cockpit
PGUSER=cockpit_app
PGPASSWORD=troque-esta-senha

# --- Embeddings (camada plugável) --------------------------------------------
# Modelo de embeddings. Dimensão fixa em 1536 (conforme SPEC §6/§7).
# Se EMBED_URL não estiver definido (ou estiver indisponível), embed.py e
# ask.py usam um fallback local determinístico (hash) de dimensão 1536,
# permitindo rodar 100% offline em demo.
EMBED_MODEL=text-embedding-3-small

# Endpoint HTTP do serviço de embeddings (opcional).
# Espera um POST JSON {"model": <EMBED_MODEL>, "input": [<textos>]} e resposta
# no formato OpenAI-like: {"data": [{"embedding": [...1536 floats...]}, ...]}.
# Deixe em branco para forçar o fallback local determinístico (offline).
# EMBED_URL=http://localhost:8088/v1/embeddings

# Chave opcional do serviço de embeddings (enviada como Authorization: Bearer).
# EMBED_API_KEY=
